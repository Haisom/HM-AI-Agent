# Copy this file to .env for local development.

# LLM provider
OPENAI_API_KEY=
OPENAI_MODEL=

# MCP
MCP_CONFIG_PATH=

# MCP Brasil optional credentials
# Most mcp-brasil APIs work without keys; fill only the providers you use.
TRANSPARENCIA_API_KEY=
DATAJUD_API_KEY=
META_ACCESS_TOKEN=

# MCP Brasil runtime options
MCP_BRASIL_COMMAND=uvx
MCP_BRASIL_TOOL_SEARCH=bm25
MCP_BRASIL_HTTP_TIMEOUT=30.0
MCP_BRASIL_HTTP_MAX_RETRIES=3

# MCP Brasil local datasets are opt-in and may download large files.
MCP_BRASIL_DATASETS=
MCP_BRASIL_DATASET_CACHE_DIR=
MCP_BRASIL_DATASET_REFRESH=auto
MCP_BRASIL_DATASET_TIMEOUT=600
MCP_BRASIL_LGPD_ALLOW_PII=

# GitHub integration
GITHUB_TOKEN=

# Runtime
LOG_LEVEL=info
ENVIRONMENT=development
